# Copy to .env and fill in for real AWS Bedrock usage.

# Which judge implementation to use: "mock" (no network, default) or "bedrock"
FIREWALL_JUDGE_BACKEND=mock

# Which agent backend to use: "mock" (no network, default) or "bedrock"
FIREWALL_AGENT_BACKEND=mock

# AWS / Bedrock settings (only needed when backend=bedrock)
AWS_REGION=us-east-1
FIREWALL_BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Risk score (0.0-1.0) at or above which a request is blocked
FIREWALL_BLOCK_THRESHOLD=0.6

# Score at/above which heuristics short-circuit and block without calling the judge
FIREWALL_HEURISTIC_BLOCK_THRESHOLD=0.9
